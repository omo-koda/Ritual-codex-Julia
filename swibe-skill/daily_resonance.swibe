skill daily_routine {
  secure {
    let today = date.weekday()
    let routine = load_routine("~/.daily_routine.json")
    let config = routine[today]

    if config {
      println("Today is " + today + ". Principle: " + config.principle)
      println("Virtue: " + config.virtue)
      
      if config.element {
        println("Feeling " + config.element + " today...")
      }

      -- On-demand triggers
      let input = "invoke crypto ritual" -- Mock input for now
      if contains(input, "invoke") {
        if config.mantra {
          println(config.mantra)
        }
      }
      
      if contains(input, "crypto") {
        if config.crypto_sector {
          println("Sector focus: " + config.crypto_sector)
        }
      }
    } else {
      println("No routine set for " + today + ". Breathing neutral.")
    }
  }
}

fn main() {
  daily_routine.actions()
}
