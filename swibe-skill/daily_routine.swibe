skill daily_routine {
  secure {
    let today = date.weekday()
    let routine = load_routine("~/.daily_routine.json")
    let config = routine[today]

    if config {
      println("Today is " + today + ". Applying config...")
      
      -- 1. Always-on neutral primitives
      if config.color { set_ui_color(config.color) }
      if config.tone { play_tone(config.tone) }
      if config.principle { set_principle_filter(config.principle) }
      if config.virtue { apply_virtue_check(config.virtue) }

      -- 2. On-demand flavor
      if config.element {
        println("Feeling " + config.element + " today...")
      }

      -- 3. On-demand triggers
      let input = "invoke crypto ritual" -- Mock input
      if contains(input, "invoke") {
        if config.mantra { println(config.mantra) }
      }
      
      if contains(input, "crypto") {
        if config.crypto_sector { println("Sector focus: " + config.crypto_sector) }
      }
    } else {
      println("No routine set for " + today + ". Breathing neutral.")
    }
  }
}

fn main() {
  daily_routine.actions()
}
